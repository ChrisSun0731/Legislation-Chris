{
  "name": "functions",
  "scripts": {
    "lint": "eslint -c eslint.config.mjs \"./src*/**/*.{ts,js,cjs,mjs,vue}\" .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
